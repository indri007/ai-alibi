# ============================================================
# Creative Alibi - Backend Environment Variables
# Rename file ini menjadi .env dan isi API key Anda
# ============================================================

# Port untuk server proxy berjalan
PORT=3001

# ================= Basic Auth (Opsional) ===================
# Aktifkan untuk mengamankan proxy server jika di-hosting publik
# Biarkan kosong untuk nonaktifkan (mode local development)
PROXY_USERNAME=
PROXY_PASSWORD=

# ================= Layer 3 API Keys =========================

# 1. IBM watsonx.ai API Key & Project ID
# Direkomendasikan untuk deteksi forensik menggunakan model IBM Granite
WATSONX_API_KEY="masukkan_ibm_cloud_api_key_anda_di_sini"
WATSONX_PROJECT_ID="masukkan_watsonx_project_id_anda_di_sini"
WATSONX_REGION="us-south"

# 2. GPTZero API Key (https://gptzero.me/)
# Rekomendasi utama untuk tingkat forensik/akademik tertinggi
GPTZERO_API_KEY="masukkan_api_key_gptzero_anda_di_sini"

# 3. ZeroGPT API Key via RapidAPI (https://rapidapi.com/zerogpt-zerogpt-default/api/zerogpt)
# Alternatif yang lebih murah/gratis via RapidAPI
ZEROGPT_API_KEY="masukkan_api_key_zerogpt_rapidapi_anda_di_sini"
