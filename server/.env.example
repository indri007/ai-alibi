# ============================================================
# Creative Alibi - Backend Environment Variables (Fixed)
# Rename file ini menjadi .env dan isi API key Anda
# ============================================================

# Port untuk server proxy berjalan
PORT=3001

# =================== Desklib Detector (Local) ===================
# URL Python sidecar untuk model desklib/ai-text-detector-v1.01
# - Local dev: http://127.0.0.1:5000
# - Cloud Run: https://desklib-detector-XXXXX.asia-southeast2.run.app
DESKLIB_URL="http://127.0.0.1:5000"
DESKLIB_TIMEOUT_MS="60000"

# =================== HIX Bypass (Premium) ===================
# HIX AI bypass premium account
HIX_EMAIL=""
HIX_PASSWORD=""

# ================= IBM watsonx.ai API ===================
# Daftar di: https://cloud.ibm.com/
WATSONX_API_KEY=""
WATSONX_PROJECT_ID=""
WATSONX_REGION="us-south"

# =================== GPTZero API ===================
# Daftar di: https://gptzero.me/
GPTZERO_API_KEY=""

# =================== ZeroGPT API ===================
# Via RapidAPI: https://rapidapi.com/zerogpt-zerogpt-default/api/zerogpt
ZEROGPT_API_KEY=""
# ZEROGPT_API_URL=https://api.zerogpt.com/api/detect/detectText

# =================== API Key Auth ===================
# Aktifkan untuk mengamankan proxy server jika di-hosting publik
API_KEY=""

# =================== Rate Limiting ===================
RATE_LIMIT_MAX="20"

# =================== Google OAuth ===================
# Opsional. Aktifkan login Google untuk dashboard.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
SESSION_SECRET=""
