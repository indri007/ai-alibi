# Creative Alibi v2.0 - Backend Proxy Environment Variables

# Backend server port
PORT=3001

# GPTZero API
# Daftar di: https://gptzero.me/
GPTZERO_API_KEY=your_gptzero_api_key_here

# ZeroGPT API
# Via RapidAPI atau direct
ZEROGPT_API_KEY=your_zerogpt_api_key_here
ZEROGPT_API_URL=https://api.zerogpt.com/api/detect/detectText
# ZEROGPT_API_HOST=zerogpt.p.rapidapi.com # Uncomment jika menggunakan RapidAPI
