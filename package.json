{
  "name": "creative-alibi-word-addin",
  "version": "1.0.0",
  "description": "Word Add-in — merekam metadata proses kerja (bukan konten) untuk membuktikan karya dibuat manusia. Menghasilkan Human Rhythm Score & Sertifikat Proses.",
  "main": "src/taskpane/taskpane.js",
  "scripts": {
    "start": "office-addin-debugging start manifest.xml",
    "stop": "office-addin-debugging stop manifest.xml",
    "dev-server": "webpack serve --mode development",
    "start-server": "node server/index.js",
    "build": "webpack --mode production",
    "validate": "office-addin-manifest validate manifest.xml",
    "server": "node server/index.js",
    "dev:all": "start npm run server && npm run start"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2"
  },
  "devDependencies": {
    "copy-webpack-plugin": "^11.0.0",
    "html-webpack-plugin": "^5.6.0",
    "office-addin-debugging": "^5.1.4",
    "office-addin-dev-certs": "^1.13.0",
    "office-addin-manifest": "^1.13.0",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.4"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
